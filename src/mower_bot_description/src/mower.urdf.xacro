<?xml version="1.0"?>
<robot name="tracked_mower" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="base_mass" value="13.14"/>
  <xacro:property name="base_x" value="0.50"/>
  <xacro:property name="base_y" value="0.24"/>
  <xacro:property name="base_z" value="0.14"/>

  <xacro:property name="track_mass" value="6.06"/>
  <xacro:property name="track_width" value="0.10"/>
  <xacro:property name="track_length" value="0.50"/> <xacro:property name="track_height" value="0.09"/>
  <xacro:property name="track_offset_y" value="0.20"/> <xacro:property name="drive_wheel_radius" value="0.095"/> <xacro:property name="drive_wheel_width" value="0.05"/>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${drive_wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="${base_x} ${base_y} ${base_z}"/>
      </geometry>
      <material name="Green">
        <color rgba="0.1 0.6 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_x} ${base_y} ${base_z}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.34" iyz="0" izz="0.30"/>
    </inertial>
  </link>

  <xacro:macro name="visual_track" params="prefix reflect">
    <link name="${prefix}_track_mid_visual">
      <visual>
        <geometry>
          <box size="${track_length - 0.18} ${track_width} ${track_height}"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      </link>

    <joint name="${prefix}_track_mid_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_track_mid_visual"/>
      <origin xyz="0 ${reflect * track_offset_y} 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}_track_front_visual">
      <visual>
        <geometry>
          <cylinder radius="${track_height / 2}" length="${track_width}"/>
        </geometry>
        <material name="Black"/>
      </visual>
    </link>

    <joint name="${prefix}_track_front_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_track_front_visual"/>
      <origin xyz="${(track_length - 0.18) / 2} ${reflect * track_offset_y} 0" rpy="1.5708 0 0"/>
    </joint>

    <link name="${prefix}_track_rear_visual">
      <visual>
        <geometry>
          <cylinder radius="${track_height / 2}" length="${track_width}"/>
        </geometry>
        <material name="Black"/>
      </visual>
    </link>

    <joint name="${prefix}_track_rear_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_track_rear_visual"/>
      <origin xyz="-${(track_length - 0.18) / 2} ${reflect * track_offset_y} 0" rpy="1.5708 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:visual_track prefix="left" reflect="1"/>
  <xacro:visual_track prefix="right" reflect="-1"/>


  <xacro:macro name="drive_wheel" params="prefix location reflect_x reflect_y">
    <link name="${prefix}_${location}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}"/>
        </geometry>
        <material name="Transparent">
          <color rgba="1 0 0 0.3"/> 
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>2.0</mu> 
              <mu2>2.0</mu2>
              <fdir1>1 0 0</fdir1> 
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>10000000.0</kp> 
              <kd>1.0</kd>
            </ode>
          </contact>
        </surface>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${prefix}_${location}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_${location}_wheel"/>
      <origin xyz="${reflect_x * 0.18} ${reflect_y * track_offset_y} 0" rpy="-1.5708 0 0"/> 
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="front" location="left"  reflect_x="1"  reflect_y="1"/>
  <xacro:drive_wheel prefix="front" location="right" reflect_x="1"  reflect_y="-1"/>
  <xacro:drive_wheel prefix="rear"  location="left"  reflect_x="-1" reflect_y="1"/>
  <xacro:drive_wheel prefix="rear"  location="right" reflect_x="-1" reflect_y="-1"/>

  <xacro:macro name="flipper" params="prefix location reflect_x reflect_y">
    <link name="${prefix}_${location}_flipper">
      <visual>
        <origin xyz="${reflect_x * 0.165} 0 0" rpy="0 0 0"/> <geometry>
           <box size="0.33 0.05 0.06"/> </geometry>
        <material name="Grey">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="${reflect_x * 0.165} 0 0" rpy="0 0 0"/>
        <geometry>
           <box size="0.33 0.05 0.06"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.75"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${prefix}_${location}_flipper_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_${location}_flipper"/>
      <origin xyz="${reflect_x * 0.25} ${reflect_y * 0.27} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="50" velocity="1.0"/>
    </joint>
  </xacro:macro>

  <xacro:flipper prefix="front" location="left"  reflect_x="1"  reflect_y="1"/>
  <xacro:flipper prefix="front" location="right" reflect_x="1"  reflect_y="-1"/>
  <xacro:flipper prefix="rear"  location="left"  reflect_x="-1" reflect_y="1"/>
  <xacro:flipper prefix="rear"  location="right" reflect_x="-1" reflect_y="-1"/>

<!--***********************************************************-->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
      <material name="Pink"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.15 0 0.2" rpy="0 0 0"/> 
  </joint>

  <link name="camera_depth_frame"/>
  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> 
  </joint>

  <link name="gps_link">
    <visual>
      <geometry><cylinder radius="0.02" length="0.01"/></geometry>
      <material name="Black"><color rgba="1 1 1 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.02" length="0.01"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin xyz="-0.1 0 0.3" rpy="0 0 0"/> 
  </joint>
<!--***********************************************************-->

  <gazebo>
    <plugin name="skid_steer_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
        </ros>

      <num_wheel_pairs>2</num_wheel_pairs>
      
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <wheel_separation>${track_offset_y * 2}</wheel_separation>
      <wheel_diameter>${drive_wheel_radius * 2}</wheel_diameter>
      
      <max_wheel_torque>80</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf> <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>front_left_flipper_joint</joint_name>
      <joint_name>front_right_flipper_joint</joint_name>
      <joint_name>rear_left_flipper_joint</joint_name>
      <joint_name>rear_right_flipper_joint</joint_name>
    </plugin>

    <sensor name="lidar" type="ray">
      <pose> 0 0 0 0 0 0 </pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.3</min>
          <max>12</max>
        </range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <argument>~/out:=scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>

    <sensor name="imu_sensor" type="imu">
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <argument>~/out:=imu</argument>
        </ros>
        <frame_name>imu_link</frame_name>
      </plugin>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
    </sensor>
  </gazebo>

</robot>