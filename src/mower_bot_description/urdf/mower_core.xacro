<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" >

    <xacro:property name="base_mass" value="13.14"/>
    <xacro:property name="base_x" value="0.76"/>
    <xacro:property name="base_y" value="0.60"/>
    <xacro:property name="base_z" value="0.14"/>

    <xacro:property name="track_offset_y" value="0.25"/>
    <xacro:property name="drive_wheel_radius" value="0.05"/> 
    <xacro:property name="drive_wheel_width" value="0.05"/>

    <link name="base_footprint"/>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual name="base_link">
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <!-- ใช้ไฟล์ก้อนเดียวจบตามที่พี่ต้องการครับ -->
                <mesh filename="package://mower_bot_description/meshes/Chassis_Center_link.STL" />
            </geometry>
            <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0.17" rpy="0 0 0"/>
            <geometry>
                <box size="${base_x} ${base_y} ${base_z}"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <mass value="13.14"/>
            <inertia 
                ixx="${(13.14/12) * (0.24*0.24 + 0.14*0.14)}" ixy="0" ixz="0"
                iyy="${(13.14/12) * (0.50*0.50 + 0.14*0.14)}" iyz="0"
                izz="${(13.14/12) * (0.50*0.50 + 0.24*0.24)}"
            />
        </inertial>
    </link>

    <xacro:macro name="drive_wheel" params="prefix location reflect_x reflect_y offset_x">
        <link name="${prefix}_${location}_wheel">
            <!--<visual>
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}"/>
                </geometry>
                <material name="transparent">
                    <color rgba="1 0 0 0.3"/> 
                </material>
            </visual>-->
            <collision>
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}"/>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>2.0</mu> 
                            <mu2>0.001</mu2>
                            <fdir1>1 0 0</fdir1>
                            <slip1>0.0</slip1>
                            <slip2>0.0</slip2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>10000000.0</kp> 
                            <kd>1.0</kd>
                        </ode>
                    </contact>
                </surface>
            </collision>
            <inertial>
                <mass value="2.0"/>
                <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
            </inertial>
        </link>

        <joint name="${prefix}_${location}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_${location}_wheel"/>
            <origin xyz="${offset_x} ${reflect_y * track_offset_y} -0.001" rpy="-1.5708 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>
    </xacro:macro>

    <xacro:macro name="passive_wheel" params="prefix location reflect_y offset_x">
        <link name="${prefix}_${location}_wheel">
            <!--<visual>
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}"/>
                </geometry>
                <material name="transparent">
                    <color rgba="0 0 1 0.3"/> 
                </material>
            </visual>-->
            <collision>
                <geometry>
                    <sphere radius="${drive_wheel_radius}"/>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.0</mu> 
                            <mu2>0.0</mu2>
                            <slip1>1.0</slip1>
                            <slip2>1.0</slip2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <inertial>
                <mass value="0.5"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>

        <joint name="${prefix}_${location}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_${location}_wheel"/>
            <origin xyz="${offset_x} ${reflect_y * track_offset_y} -0.001" rpy="-1.5708 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>
    </xacro:macro>
    
    <xacro:passive_wheel prefix="front" location="left"  reflect_y="1"  offset_x="0.5"/>
    <xacro:passive_wheel prefix="mid"   location="left"  reflect_y="1"  offset_x="0.0"/>
    <xacro:drive_wheel   prefix="rear"  location="left"  reflect_x="-1" reflect_y="1" offset_x="-0.5"/>

    <xacro:passive_wheel prefix="front" location="right" reflect_y="-1" offset_x="0.5"/>
    <xacro:passive_wheel prefix="mid"   location="right" reflect_y="-1" offset_x="0.0"/>
    <xacro:drive_wheel   prefix="rear"  location="right" reflect_x="-1" reflect_y="-1" offset_x="-0.5"/>

    <xacro:macro name="visual_track" params="prefix reflect filename">
        <link name="${prefix}_track_visual">
            <visual>
                <origin xyz="0 0 0.03" rpy="1.5708 0 3.14"/>
                <geometry>
                     <mesh filename="package://mower_bot_description/meshes/${filename}" scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="black">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0.03" rpy="1.5708 0 3.14"/> 
                <geometry>
                    <mesh filename="package://mower_bot_description/meshes/${filename}" scale="0.001 0.001 0.001"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="2.0"/>
                <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
            </inertial>
        </link>

        <joint name="${prefix}_track_joint" type="fixed">
            <parent link="base_link"/>
            <child link="${prefix}_track_visual"/>
            <origin xyz="0 0.5 0" rpy="0 0 0"/>
        </joint>
    </xacro:macro>

    <!-- ปิดการใช้งาน visual_track เก่าทิ้งทั้งหมด เพื่อไม่ให้ภาพซ้อนกับตัวรถก้อนใหญ่ครับ -->
    <!--
    <xacro:visual_track prefix="left"  reflect="1"  filename="L_URDF_Assem1_3.STL"/>
    <xacro:visual_track prefix="right" reflect="-1" filename="R_URDF_Assem1_3.STL"/>
    -->

    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="lidar_mount_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="-0.25 0 0.545" rpy="0 0 0"/>
    </joint>

    <link name="laser_frame">
        <visual>
            <geometry><box size="0.01 0.01 0.01"/></geometry>
            <material name="black"/>
        </visual>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="lidar_link"/>
        <child link="laser_frame"/>
        <origin xyz="0 0 0.0" rpy="0 0 3.1415"/> </joint>

    <link name="imu_link"/>
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="camera_link">
        <visual>
            <geometry><box size="0.025 0.09 0.025"/></geometry>
            <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
        </visual>
        <collision>
            <geometry><box size="0.025 0.09 0.025"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>
    
    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="-0.13 0 0.45" rpy="0 0 0"/> 
    </joint>

    <link name="camera_depth_frame"/>
    <joint name="camera_depth_joint" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_depth_frame"/>
        <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/> 
    </joint>

    <link name="gps_link">
        <visual>
            <geometry><cylinder radius="0.02" length="0.01"/></geometry>
            <material name="white"><color rgba="1 1 1 1.0"/></material>
        </visual>
        <collision>
            <geometry><cylinder radius="0.02" length="0.01"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="gps_joint" type="fixed">
        <parent link="base_link"/>
        <child link="gps_link"/>
        <origin xyz="-0.12 0 0.38" rpy="0 0 0"/> 
    </joint>

    <!-- Ultrasonic Sensors -->
    <!-- Center Sonar -->
    <link name="sonar_center">
        <visual><geometry><box size="0.02 0.04 0.02"/></geometry><material name="grey"/></visual>
    </link>
    <joint name="sonar_center_joint" type="fixed">
        <parent link="base_link"/>
        <child link="sonar_center"/>
        <origin xyz="0.1 0 0.35" rpy="0 0 0"/>
    </joint>

    <!-- Left Sonar -->
    <link name="sonar_left">
        <visual><geometry><box size="0.02 0.04 0.02"/></geometry><material name="grey"/></visual>
    </link>
    <joint name="sonar_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="sonar_left"/>
        <!-- Pointing 45 degrees left (0.785 rad) -->
        <origin xyz="0.1 0.2 0.35" rpy="0 0 0.7854"/>
    </joint>

    <!-- Right Sonar -->
    <link name="sonar_right">
        <visual><geometry><box size="0.02 0.04 0.02"/></geometry><material name="grey"/></visual>
    </link>
    <joint name="sonar_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="sonar_right"/>
        <!-- Pointing 45 degrees right (-0.785 rad) -->
        <origin xyz="0.1 -0.2 0.35" rpy="0 0 -0.7854"/>
    </joint>

</robot>